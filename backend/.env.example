# ============================================================
# FinAI Backend — Environment Variables
# Copy this file to .env and fill in your keys.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------------
# Database (required)
# ------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/finai

# ------------------------------------------------------------------
# LLM Provider — OpenRouter (ONE key for ALL models)
# Get your key: https://openrouter.ai/keys
# ------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-...

# ------------------------------------------------------------------
# Model Selection — swap models instantly via env vars
# ------------------------------------------------------------------
# All models go through OpenRouter. Use any model from openrouter.ai/models
#
# Recommended for FinAI:
#   grok-4-1-fast-reasoning     — xAI        | $0.20/$0.50 per M  | 2M ctx  | DEFAULT
#   claude-sonnet-4-6           — Anthropic   | $3/$15 per M       | 200K ctx
#   kimi-k2.5                   — Moonshot    | $0.60/$3.00 per M  | 256K ctx
#   deepseek-chat               — DeepSeek    | $0.14/$0.28 per M  | 128K ctx
#
# Or use full OpenRouter IDs directly:
#   x-ai/grok-4-1-fast-reasoning
#   anthropic/claude-sonnet-4.6
#   moonshotai/kimi-k2.5
LLM_MODEL=grok-4-1-fast-reasoning
LLM_TEMPERATURE=0.2

# Classifier (lightweight, for doc type detection):
CLASSIFIER_MODEL=grok-4-1-fast-non-reasoning

# Embeddings:
EMBEDDING_MODEL=text-embedding-3-small

# ------------------------------------------------------------------
# Supabase (optional — uses Docker PostgreSQL for local dev)
# ------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ------------------------------------------------------------------
# External Data Sources (optional for initial testing)
# ------------------------------------------------------------------
# UK Companies House REST API (FREE) — developer.company-information.service.gov.uk
COMPANIES_HOUSE_API_KEY=

# FRED macroeconomic data (FREE) — fred.stlouisfed.org
FRED_API_KEY=

# ------------------------------------------------------------------
# Observability (optional)
# ------------------------------------------------------------------
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=finai

# ------------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
