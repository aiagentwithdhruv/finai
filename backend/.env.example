# ============================================================
# FinAI Backend — Environment Variables
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------------
# Supabase (required)
# ------------------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ------------------------------------------------------------------
# Database (required)
# ------------------------------------------------------------------
# Must use postgresql+asyncpg:// scheme for SQLAlchemy async
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/finai

# ------------------------------------------------------------------
# LLM Providers (at least Anthropic OR OpenAI required)
# ------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
XAI_API_KEY=                    # Optional — for Grok models (x.ai/api)
MOONSHOT_API_KEY=               # Optional — for Kimi models (platform.moonshot.ai)

# ------------------------------------------------------------------
# Model Selection — swap models instantly via env vars
# ------------------------------------------------------------------
# Supported LLM models:
#   claude-sonnet-4-6           — Anthropic  | $3/$15 per M tokens  | 200K ctx (1M beta)
#   grok-4-1-fast-reasoning     — xAI        | $0.20/$0.50 per M    | 2M context
#   kimi-k2.5                   — Moonshot   | $0.60/$3.00 per M    | 256K context
LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.2

# Classifier (lightweight, for doc type detection):
#   claude-haiku-4-5-20251001   — Anthropic  | $0.80/$4.00 per M
CLASSIFIER_MODEL=claude-haiku-4-5-20251001

# Embeddings:
#   text-embedding-3-small      — OpenAI     | $0.02 per M tokens   | 1536 dims
EMBEDDING_MODEL=text-embedding-3-small

# ------------------------------------------------------------------
# External Data Sources
# ------------------------------------------------------------------
# UK Companies House REST API (FREE) — developer.company-information.service.gov.uk
COMPANIES_HOUSE_API_KEY=your_companies_house_api_key

# FRED macroeconomic data (FREE) — fred.stlouisfed.org
FRED_API_KEY=your_fred_api_key

# Alpha Vantage (optional — yfinance used as primary)
ALPHA_VANTAGE_API_KEY=

# ------------------------------------------------------------------
# Observability (optional but recommended)
# ------------------------------------------------------------------
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=finai

# ------------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
